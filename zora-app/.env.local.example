# === Firebase Web SDK (from Firebase console > Project settings > Your apps) ===
# These NEXT_PUBLIC_* vars are sent to the browser. That's fine for Firebase —
# auth/firestore/storage security is enforced by rules, not by hiding the key.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Google Gemini (from Google AI Studio > Get API key) ===
# Server-side ONLY — no NEXT_PUBLIC_ prefix. Plan §3.4 forbids exposing this in client code.
GEMINI_API_KEY=

# Optional failover keys. /api/chat tries GEMINI_API_KEY first, then _2, then _3 when a key
# is quota-exhausted (HTTP 429). NOTE: free-tier quotas are per Google Cloud PROJECT, so a
# fallback key only adds real headroom if it comes from a DIFFERENT project than GEMINI_API_KEY.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# === Web3Forms (optional — recommended over FormSubmit) ===
# Used by the /contact form to forward submissions to xorvion.ai@gmail.com.
# Get your access key at https://web3forms.com/ — free plan covers 250 submissions/month.
# Safe to expose publicly (it identifies the form, not your account).
# If unset, the contact form falls back to FormSubmit.co.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
